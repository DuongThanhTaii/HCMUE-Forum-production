VITE_API_URL=http://localhost:5034
VITE_UEBOT_WEBAPP_URL=http://localhost:3000
VITE_UEBOT_SYNC_API_URL=http://localhost:4010

# Co-Pilot feature switch
VITE_ENABLE_COPILOT_ACTIONS=true

# Azure login (see src/features/auth/hooks/useLoginForm.ts — all three required when enabled)
VITE_ENABLE_AZURE_LOGIN=false
VITE_AZURE_TENANT_ID=
VITE_AZURE_CLIENT_ID=
# API scope exposed by the backend app registration, e.g. api://<api-client-id>/.default or api://.../access_as_user
VITE_AZURE_API_SCOPE=
# Optional — not read by useLoginForm today (redirectUri is window.location.origin + '/login')
VITE_AZURE_REDIRECT_URI=http://localhost:5173/auth-popup.html
