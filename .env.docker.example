# Copy to .env.docker for local overrides:
# cp .env.docker.example .env.docker

# Bind DB ports to localhost by default for better isolation
DB_BIND_HOST=127.0.0.1

# Images
POSTGRES_IMAGE=postgres:16-alpine
MONGODB_IMAGE=mongo:7-jammy
REDIS_IMAGE=redis:7-alpine

# Ports (host side) — match docker-compose defaults + appsettings.Development.json for `dotnet run`
POSTGRES_PORT=5433
MONGODB_PORT=27018
REDIS_PORT=6380

# PostgreSQL
POSTGRES_USER=unihub
POSTGRES_PASSWORD=unihub_dev_2026
POSTGRES_DB=unihub

# MongoDB
MONGO_ROOT_USER=unihub
MONGO_ROOT_PASSWORD=unihub_dev_2026
MONGO_DB=unihub
# DB name the API uses for logs/chat (backup script reads appsettings.Development.json or this):
# MONGO_BACKUP_DB=unihub_db_dev

# Redis
REDIS_PASSWORD=change_me_redis
REDIS_APPENDONLY=yes

# Full stack (optional): docker compose --env-file .env.docker up -d --build
# API on host: http://localhost:5034  |  Web (nginx): http://localhost:5173
# API_PORT=5034
# WEB_PORT=5173
# Public URL baked into the FE build + Chat links (must match API_PORT mapping)
# VITE_API_URL=http://localhost:5034