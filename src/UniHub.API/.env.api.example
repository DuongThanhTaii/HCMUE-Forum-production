# Optional: set these in the OS / launch profile if you do not use appsettings.Development.json.
# ASP.NET Core maps __ to nested config (e.g. ConnectionStrings__DefaultConnection).
# Primary local config: src/UniHub.API/appsettings.Development.json
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5034

# Database connection strings
ConnectionStrings__DefaultConnection=Host=127.0.0.1;Port=5432;Database=unihub;Username=unihub;Password=unihub_dev_2026
ConnectionStrings__PostgreSQL=Host=127.0.0.1;Port=5432;Database=unihub;Username=unihub;Password=unihub_dev_2026
ConnectionStrings__MongoDB=mongodb://unihub:unihub_dev_2026@127.0.0.1:27017/unihub?authSource=admin
ConnectionStrings__Redis=127.0.0.1:6379,password=change_me_redis

# Mongo settings
MongoDbSettings__ConnectionString=mongodb://unihub:unihub_dev_2026@127.0.0.1:27017/unihub?authSource=admin
MongoDbSettings__DatabaseName=unihub

# Redis backplane (SignalR)
RedisBackplane__ConnectionString=127.0.0.1:6379,password=change_me_redis

# UEBot integration (Forum -> sync-api exchange)
Integrations__UEBot__BaseUrl=http://localhost:4010
Integrations__UEBot__ExchangePath=/integrations/forum/exchange
Integrations__UEBot__SyncApiBaseUrl=http://localhost:4010
Integrations__UEBot__SharedSecret=replace_with_strong_shared_secret

# Azure AD dual-auth (optional; keep Disabled by default)
Authentication__AzureAd__Enabled=false
Authentication__AzureAd__TenantId=your-tenant-id
Authentication__AzureAd__ClientId=your-app-client-id
Authentication__AzureAd__ClientSecret=your-app-client-secret
Authentication__AzureAd__Audience=api://your-app-client-id
Authentication__AzureAd__Authority=https://login.microsoftonline.com/your-tenant-id/v2.0
Authentication__AzureAd__ValidIssuer=https://login.microsoftonline.com/your-tenant-id/v2.0
Authentication__AzureAd__EnableGuestInvitationOnLocalLogin=false
Authentication__AzureAd__InvitationRedirectUrl=http://localhost:5173
Authentication__AzureAd__GraphBaseUrl=https://graph.microsoft.com
Authentication__AzureAd__InvitationSendMail=true